      "package": "com.thom_oliver.Testemobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2c3a4a52-dbfe-437e-ba87-a3fcc89067b2"
